		{
			"name": "End-to-End Flow Test",
			"description": "Run these requests in order to verify the complete flow:\n1. Login → get JWT\n2. Create Order → persisted to DB, outbox event created\n3. Wait 1-2 seconds for outbox publisher to send to Kafka\n4. Verify Kafka metrics show the message was sent\n5. Verify notification service consumed the event\n\nFor WebSocket verification, open the UI at http://localhost:3000 and watch the Live Notifications panel.",
			"item": [
				{
					"name": "1. Login (Get Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('jwt_token', jsonData.token);",
									"pm.test('Token received', function () {",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/auth/login",
							"host": ["{{order_service_url}}"],
							"path": ["auth", "login"]
						}
					},
					"response": []
				},
				{
					"name": "2. Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Order created (201)', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('order_id', jsonData.orderId);",
									"pm.test('Has orderId', function () {",
									"    pm.expect(jsonData.orderId).to.be.a('string');",
									"});",
									"pm.test('Status is CREATED', function () {",
									"    pm.expect(jsonData.status).to.eql('CREATED');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
