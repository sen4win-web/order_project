{
	"info": {
		"_postman_id": "order-processing-platform",
		"name": "Order Processing Platform",
		"description": "API collection for the Microservices-Based Order Processing Platform.\n\n- Order Service runs on port 8081\n- Notification Service runs on port 8082\n\nFlow: Client → Order Service → Kafka → Notification Service → WebSocket",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "order_service_url",
			"value": "http://localhost:8081",
			"type": "string"
		},
		{
			"key": "notification_service_url",
			"value": "http://localhost:8082",
			"type": "string"
		},
		{
			"key": "order_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"description": "JWT authentication endpoints. Run 'Login' first to get a token.",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has token', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.collectionVariables.set('jwt_token', jsonData.token);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/auth/login",
							"host": ["{{order_service_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Authenticates and returns a JWT token. The token is auto-saved to the jwt_token collection variable."
					},
					"response": []
				},
				{
					"name": "Login (Invalid Credentials)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 401', function () {",
									"    pm.response.to.have.status(401);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"wrongpassword\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/auth/login",
							"host": ["{{order_service_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Attempts login with wrong credentials. Should return 401."
					},
					"response": []
				}
			]
		},
		{
			"name": "Order Service",
			"description": "Endpoints for creating and retrieving orders.",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has orderId', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.orderId).to.be.a('string');",
									"    pm.collectionVariables.set('order_id', jsonData.orderId);",
									"});",
									"",
									"pm.test('Response has status', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.be.a('string');",
									"});",
									"",
									"pm.test('Response has createdAt', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.createdAt).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customerId\": \"cust-001\",\n    \"productId\": \"prod-abc\",\n    \"quantity\": 2,\n    \"idempotencyKey\": \"req-12345\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/orders",
							"host": ["{{order_service_url}}"],
							"path": ["orders"]
						},
						"description": "Creates a new order. The order is persisted to PostgreSQL and an event is published to Kafka via the outbox pattern.\n\nThe idempotencyKey is optional — if provided, duplicate requests with the same key return the existing order."
					},
					"response": []
				},
				{
					"name": "Create Order (Idempotent Retry)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customerId\": \"cust-001\",\n    \"productId\": \"prod-abc\",\n    \"quantity\": 2,\n    \"idempotencyKey\": \"req-12345\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/orders",
							"host": ["{{order_service_url}}"],
							"path": ["orders"]
						},
						"description": "Sends the same idempotencyKey as 'Create Order'. Should return the existing order instead of creating a duplicate."
					},
					"response": []
				},
				{
					"name": "Create Order (No Idempotency Key)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customerId\": \"cust-002\",\n    \"productId\": \"prod-xyz\",\n    \"quantity\": 5\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/orders",
							"host": ["{{order_service_url}}"],
							"path": ["orders"]
						},
						"description": "Creates an order without an idempotency key."
					},
					"response": []
				},
				{
					"name": "Get Order by ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has orderId', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.orderId).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{order_service_url}}/orders/{{order_id}}",
							"host": ["{{order_service_url}}"],
							"path": ["orders", "{{order_id}}"]
						},
						"description": "Retrieves an order by its UUID. Run 'Create Order' first to populate the order_id variable."
					},
					"response": []
				},
				{
					"name": "Get Order (Not Found)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 404', function () {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{order_service_url}}/orders/00000000-0000-0000-0000-000000000000",
							"host": ["{{order_service_url}}"],
							"path": ["orders", "00000000-0000-0000-0000-000000000000"]
						},
						"description": "Attempts to retrieve a non-existent order. Should return 404."
					},
					"response": []
				}
			]
		},
