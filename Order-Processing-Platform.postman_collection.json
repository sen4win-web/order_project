		{
			"name": "Kafka & Messaging",
			"description": "Verify Kafka event flow. After creating an order, the outbox publisher sends events to Kafka, and the notification service consumes them.\n\nNote: These use Kafka metrics exposed via actuator to verify messaging is working.",
			"item": [
				{
					"name": "Kafka Producer Metrics (Order Service)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Contains kafka producer metrics', function () {",
									"    pm.expect(pm.response.text()).to.include('kafka_producer');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{order_service_url}}/actuator/prometheus",
							"host": ["{{order_service_url}}"],
							"path": ["actuator", "prometheus"]
						},
						"description": "Fetches Prometheus metrics from Order Service. Look for kafka_producer_* metrics to verify Kafka publishing is active.\n\nKey metrics:\n- kafka_producer_record_send_total: total records sent\n- kafka_producer_record_error_total: send failures\n- kafka_producer_topic_record_send_total: records per topic"
					},
					"response": []
				},
				{
					"name": "Kafka Consumer Metrics (Notification Service)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Contains kafka consumer metrics', function () {",
									"    pm.expect(pm.response.text()).to.include('kafka_consumer');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{notification_service_url}}/actuator/prometheus",
							"host": ["{{notification_service_url}}"],
							"path": ["actuator", "prometheus"]
						},
						"description": "Fetches Prometheus metrics from Notification Service. Look for kafka_consumer_* metrics to verify Kafka consumption is active.\n\nKey metrics:\n- kafka_consumer_records_consumed_total: total records consumed\n- kafka_consumer_fetch_manager_records_lag: consumer lag per partition"
					},
					"response": []
				},
				{
					"name": "Circuit Breaker Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Contains circuit breaker metrics', function () {",
									"    pm.expect(pm.response.text()).to.include('resilience4j');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{order_service_url}}/actuator/prometheus",
							"host": ["{{order_service_url}}"],
							"path": ["actuator", "prometheus"]
						},
						"description": "Check Resilience4j circuit breaker state for the Kafka producer.\n\nKey metrics:\n- resilience4j_circuitbreaker_state: 0=CLOSED (healthy), 1=OPEN, 2=HALF_OPEN\n- resilience4j_circuitbreaker_calls_seconds_count: total calls\n- resilience4j_circuitbreaker_failure_rate: current failure rate"
					},
					"response": []
				}
			]
		},
