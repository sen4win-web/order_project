# ============================================================================
# Order Processing Platform — Environment Configuration
# Copy this file to .env and edit values as needed.
# ============================================================================

# --- Server Ports ---
ORDER_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082
UI_PORT=3000

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/orderdb
DB_USERNAME=orderuser
DB_PASSWORD=orderpass
DB_POOL_MAX=20
DB_POOL_MIN=5

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=order-events
KAFKA_PARTITIONS=3
KAFKA_CONSUMER_GROUP=notification-group
KAFKA_LISTENER_CONCURRENCY=3

# --- Outbox ---
OUTBOX_POLL_INTERVAL=1000
OUTBOX_BATCH_SIZE=50

# --- JWT ---
JWT_SECRET=change-this-to-a-long-secure-random-secret-key
JWT_EXPIRATION_MS=3600000

# --- Auth (demo credentials) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Paths (Windows local setup only, not needed for Docker) ---
# JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-17.0.18.8-hotspot
# MAVEN_HOME=C:\tools\apache-maven-3.9.14
# PG_BIN=C:\sen\soft\pgsql\bin
# PG_DATA=C:\sen\soft\pgdata
# KAFKA_HOME=C:\tools\kafka_2.13-3.9.0
